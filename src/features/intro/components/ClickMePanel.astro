---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  image: ImageMetadata;
  buttonLabel: string;
}

const { image, buttonLabel } = Astro.props;
---

<section class="intro__panel intro__panel--click-me">
  <button
    class="intro__button"
    type="button"
    aria-label={buttonLabel}
    data-intro-trigger
  >
    <Image
      src={image}
      alt=""
      class="intro__image"
      loading="eager"
      fetchpriority="high"
    />
    <span class="sr-only">{buttonLabel}</span>
  </button>
</section>
